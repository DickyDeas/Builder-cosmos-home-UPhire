# UPhire Environment Variables
# Copy this file to .env and fill in your actual values
# See LAUNCH_BRIEF.md for deployment steps

# =============================================================================
# CONTACT (Optional - used in footer, support, legal pages)
# =============================================================================
VITE_SUPPORT_EMAIL=support@uphire.com
VITE_SUPPORT_PHONE=
VITE_LEGAL_EMAIL=legal@uphire.com
VITE_PRIVACY_EMAIL=privacy@uphire.com
VITE_SALES_EMAIL=sales@uphire.com
VITE_BILLING_EMAIL=billing@uphire.com
VITE_FROM_EMAIL=noreply@uphire.com

# =============================================================================
# SUPABASE (Required for data persistence)
# =============================================================================
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Database URL - for running migrations (get from Supabase Dashboard → Settings → Database)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# =============================================================================
# STRIPE (Optional – payments handled on external website)
# =============================================================================
# Payments are managed on your main website (e.g. via Builder.ai). No Stripe setup required in UPhire.
# VITE_PRICING_URL=https://uphireiq.com/products#pricing

# =============================================================================
# AI SERVICES (Optional - uses mock data if not set)
# =============================================================================
# Grok: Used for CV screening, AI-generated content detection, job descriptions
# PREFER server-only vars (GROK_*) - VITE_* are exposed to client; use for dev only
GROK_API_KEY=xai-your_grok_api_key_here
GROK_API_URL=https://api.x.ai/v1
# Legacy (avoid for production): VITE_GROK_API_KEY, VITE_GROK_API_URL

# =============================================================================
# MARKET INTELLIGENCE (Adzuna → ITJobsWatch → Grok fallback)
# =============================================================================
# Adzuna: https://developer.adzuna.com/ - UK job/salary data
# Use ADZUNA_* (server-only) or VITE_* (dev proxy)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
# Legacy: VITE_ADZUNA_APP_ID, VITE_ADZUNA_APP_KEY

# =============================================================================
# EMAIL SERVICE (Optional - uses mock if not set)
# =============================================================================
# Brevo (recommended): https://app.brevo.com → SMTP & API → API Keys
# PREFER server-only vars - never expose API key to client
EMAIL_SERVICE_API_KEY=xkeysib-your_brevo_api_key_here
EMAIL_SERVICE_URL=https://api.brevo.com
FROM_EMAIL=noreply@uphireiq.com
# Legacy (avoid): VITE_EMAIL_SERVICE_API_KEY, VITE_EMAIL_SERVICE_URL

# =============================================================================
# JOB FEED DISTRIBUTION
# =============================================================================
# Base URL for API calls (no /app - API is at site root)
VITE_APPLY_BASE_URL=https://uphireiq.com
# Full app URL including /app subpath (for screening links, apply links, etc.)
VITE_APP_URL=https://uphireiq.com/app

# =============================================================================
# PRIVACY & TERMS (links in footer)
# =============================================================================
# VITE_PRIVACY_URL=https://uphireiq.com/privacy
# VITE_TERMS_URL=https://uphireiq.com/terms

# =============================================================================
# CALENDLY (Optional - interview scheduling)
# =============================================================================
# Get from https://calendly.com → Share → Copy link
# VITE_CALENDLY_URL=https://calendly.com/your-username/interview

# =============================================================================
# ENCRYPTION (Optional - for OAuth tokens in tenant_job_board_licenses.metadata)
# =============================================================================
# 32-byte hex key for AES-256-GCM. Generate: openssl rand -hex 32
# ENCRYPTION_KEY=your_64_char_hex_key

# =============================================================================
# RATE LIMITING (Optional - apply API)
# =============================================================================
# Upstash Redis: https://upstash.com/ - free tier, 10K req/day
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token

# =============================================================================
# UPHIRE STAFF (Optional - for All Clients admin view)
# =============================================================================
# Comma-separated emails allowed to view all tenant accounts, All Clients tab,
# shortlist delay alerts, and billing/usage visibility
# UPHIRE_STAFF_EMAILS=richard.deas@uphireiq.com

# Admin user creation (one-time, do not commit password):
# UPHIRE_ADMIN_EMAIL=richard.deas@uphireiq.com UPHIRE_ADMIN_PASSWORD=YourPassword node scripts/create-admin-user.js

# =============================================================================
# ENVIRONMENT
# =============================================================================
VITE_APP_ENV=development
VITE_DEBUG_MODE=true
